# ============================================================
# crystalclear-skills .gitignore
# ============================================================

# --- Secrets and credentials (NEVER commit these) ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
config/secrets.*

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
dist/
build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/
*.egg
MANIFEST
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# --- OS generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editors and IDEs ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.orig
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# --- Testing and CI ---
coverage/
.nyc_output/
junit.xml
test-results/

# --- Build artifacts ---
*.log
*.tmp
*.temp
*.bak
*.backup

# --- Documentation build output ---
docs/_build/
docs/site/
site/
_site/

# --- Local development overrides ---
*.local
local.*
